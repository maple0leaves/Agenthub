# Java service that owns AgentHub business data.
AGENTHUB_JAVA_BASE_URL=http://127.0.0.1:8081

# OpenAI-compatible model settings. DeepSeek, Qwen, OpenAI, and local compatible gateways can all use this shape.
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

AI_REQUEST_TIMEOUT=8
# Milvus vector search settings.
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=agent_vectors

# Embedding settings (independent of chat model).
# Defaults to BGE (BAAI/bge-m3, 1024-dim) via SiliconFlow's OpenAI-compatible API.
# If EMBEDDING_API_KEY is empty, it falls back to OPENAI_API_KEY / OPENAI_BASE_URL.
EMBEDDING_API_KEY=replace_me
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# Rerank (second stage of retrieval). Vector recall -> BGE reranker precision ranking.
# RERANK_API_KEY / RERANK_BASE_URL fall back to the EMBEDDING_* values when empty.
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_CANDIDATES=20